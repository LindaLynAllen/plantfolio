# Supabase Configuration
# These will be automatically set by Vercel when you deploy
# For local development, copy this file to .env.local and add your actual values
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (for sync operations)
# Get this from Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Planta API Configuration (for sync functionality)
PLANTA_ACCESS_TOKEN=your_planta_access_token_here
PLANTA_REFRESH_TOKEN=your_planta_refresh_token_here
